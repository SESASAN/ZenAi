# Backend (Vercel /api/*) — providers
GROQ_API_KEY=
CEREBRAS_API_KEY=

# Backend (Vercel /api/*) — firebase-admin
# Puede ser JSON completo o base64 del JSON del service account.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Frontend (Vite) — apunta al backend (opcional)
# Con rewrites en Vercel, podés usar base sin /api.
VITE_CHAT_API_URL=http://127.0.0.1:3001

# Frontend (Vite) — Firebase Web config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

